{
  "entities": {
    "Chat": {
      "title": "Chat Message",
      "description": "A chat message between the user and the AI",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this chat"
        },
        "role": {
          "type": "string",
          "enum": ["user", "model"],
          "description": "The role of the message sender"
        },
        "text": {
          "type": "string",
          "description": "The content of the message"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["userId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Stores user chat history"
    }
  }
}
