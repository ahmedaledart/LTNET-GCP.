rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: chats
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who owns this chat
    //   - role: string (required, enum: 'user', 'model') - The role of the message sender
    //   - text: string (required, max length 10000) - The content of the message
    //   - timestamp: timestamp (required) - When the message was sent
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Domain Validators
    function isValidChat(data) {
      return hasOnlyAllowedFields(['userId', 'role', 'text', 'timestamp']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 10000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                    isValidChat(request.resource.data) && 
                    uidUnchanged() && 
                    request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && 
                    isValidChat(request.resource.data) && 
                    uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
